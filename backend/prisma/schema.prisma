generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role{
  ADMIN
  EDITOR
  VIEWER
}

model Director {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  dob         DateTime
  biography   String
  imagePath   String?
  nationality String
  movies      Movie[]
  createdAt DateTime @default(now())
updatedAt DateTime @default(now()) @updatedAt
}

model Actor {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  dob         DateTime
  nationality String
  awards      Int
  biography   String
  gender      String
  imagePath   String?
  createdAt DateTime @default(now())
updatedAt DateTime @default(now()) @updatedAt
  movies      Movie[]  @relation("ActorToMovie")
}

model Movie {
  id          Int      @id @default(autoincrement())
  title       String
  duration    Int
  genre       String
  rating      Float
  directorId  Int
  description String
  language    String
  posterPath  String?
  releaseDate DateTime
  trailerId   String
  createdAt DateTime @default(now())
updatedAt DateTime @default(now()) @updatedAt

  director    Director @relation(fields: [directorId], references: [id])
  actors      Actor[]  @relation("ActorToMovie")
}

model User{

  id Int @id @default (autoincrement())
  username String @unique
  email String @unique
  password String
  firstName String
  lastName String
  role Role @default(VIEWER)

  ISActive Boolean @default(true)
  createdAt DateTime @default(now())
updatedAt DateTime @default(now()) @updatedAt
  


}